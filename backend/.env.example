# Copy this file to .env and fill in your values.

# --- LLM (Groq) ---
# Create a key at https://console.groq.com/keys and paste it here.
# Leave it blank to run the workflow on the deterministic heuristic fallback.
GROQ_API_KEY=
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2

# --- Database ---
# Local zero setup default (SQLite):
DATABASE_URL=sqlite:///./complaints.db
# Production Postgres example (matches docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://qms:qms@localhost:5432/complaints

# --- Frontend origin for CORS ---
FRONTEND_ORIGIN=http://localhost:5173
