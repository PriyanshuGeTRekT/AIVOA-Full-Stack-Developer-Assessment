# Copy this file to .env and fill in your values.

# --- LLM (Groq) ---
# Create a key at https://console.groq.com/keys and paste it here.
# Leave it blank to run the workflow on the deterministic heuristic fallback.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b
LLM_TEMPERATURE=0.2

# --- Database ---
# Local zero setup default (SQLite):
DATABASE_URL=sqlite:///./complaints.db
# Production Postgres example (matches docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://qms:qms@localhost:5432/complaints

# --- Frontend origin for CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Processing ---
# false (default): create/upload return immediately; client polls processing_state
# true: wait for the agent inside the request (useful for tests)
SYNC_PROCESSING=false

# --- Uploads ---
MAX_UPLOAD_BYTES=5242880
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.eml,.md,.csv,.png,.jpg,.jpeg,.gif,.webp

# --- Environment ---
ENVIRONMENT=development
